# ============================================================
# SmartColdMailer Frontend Environment Variables - EXAMPLE
# ============================================================
# 
# This file shows all available environment variables.
# Copy this to .env or .env.production and update values as needed.
#
# Files:
# - .env → Used for local development (npm run dev)
# - .env.production → Used for production builds (npm run build)
# - .env.example → This file (reference only)
# ============================================================

# ============================================
# API CONFIGURATION
# ============================================
# Determine your backend URL based on environment:
# 
# Local Development:
#   VITE_API_URL=http://localhost:8080
#
# Production (Render):
#   VITE_API_URL=https://cold-emailing-project.onrender.com
#
# Production (Custom Domain):
#   VITE_API_URL=https://api.yourdomain.com

VITE_API_URL=http://localhost:8080

# ============================================
# APPLICATION MODE
# ============================================
# Values: 'development' or 'production'
# Affects: logging levels, error reporting, optimizations

VITE_APP_ENV=development

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/Disable specific UI features

# Email preview feature in send emails page
VITE_ENABLE_EMAIL_PREVIEW=true

# Analytics tracking (if implemented)
VITE_ENABLE_ANALYTICS=false

# ============================================================
# QUICK START
# ============================================================
# 
# For Local Development:
#   $ cp .env.example .env
#   $ npm run dev
#
# For Production Build:
#   $ npm run build
#   (Uses .env.production variables)
#
# For Deployment on Vercel/Render:
#   1. Create .env.production with production values
#   2. Set environment variables in deployment platform settings
#   3. Deploy using platform's git integration
#
# ============================================================
