# SmartColdMailer Environment Configuration
# Copy this file to .env and fill in your actual values
# For Docker: These values are used in docker-compose.yml

# ============================================
# MONGODB DATABASE CONFIGURATION (EXTERNAL)
# ============================================
# Replace with your external MongoDB connection URI
# Example: mongodb+srv://user:password@cluster.mongodb.net/coldmailer?retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=mongodb+srv://user:password@your-cluster.mongodb.net/coldmailer?retryWrites=true&w=majority
SPRING_DATA_MONGODB_DATABASE=coldmailer
SPRING_DATA_MONGODB_AUTO_INDEX_CREATION=true

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Spring Profiles (dev, test, prod)
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8080

# ============================================
# JWT SECURITY CONFIGURATION
# ============================================
JWT_SECRET=your-secret-key-at-least-32-characters-long-change-in-production
JWT_EXPIRATION=86400000

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SMARTCOLDMAILER=DEBUG
LOGGING_LEVEL_SPRING_DATA_MONGODB=DEBUG

# ============================================
# EMAIL/SMTP CONFIGURATION
# ============================================
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Smart Cold Mailer

# ============================================
# APPLICATION FEATURES
# ============================================
# Email campaign settings
BULK_EMAIL_BATCH_SIZE=10
EMAIL_DELAY_SECONDS=5
MAX_EMAILS_PER_DAY=100

# ============================================
# SECURITY & ENCRYPTION
# ============================================
# Encryption key for sensitive data (Base64 encoded)
ENCRYPTION_KEY=MTIzNDU2Nzg5MDEyMzQ1Ng==
ENCRYPTION_ALGORITHM=AES
